# AICOS - AI Company OS Configuration
# Copy this file to .env and fill in your values

# LLM Provider
ANTHROPIC_API_KEY=your-api-key-here
AICOS_MODEL=claude-sonnet-4-5-20250929

# Company Settings
AICOS_COMPANY_CONFIG=config/company.yaml

# Dashboard
AICOS_DASHBOARD_HOST=0.0.0.0
AICOS_DASHBOARD_PORT=8080

# Email Integration (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
IMAP_HOST=
IMAP_USER=
IMAP_PASSWORD=

# Slack Integration (optional)
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
